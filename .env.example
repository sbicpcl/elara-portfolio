# Copy to .env.local and fill in to enable real email delivery from the contact form.
# Without these, /api/contact validates and logs the enquiry but does not send mail.

# Resend (https://resend.com) — leave blank to keep the form in log-only mode
RESEND_API_KEY=

# Where contact enquiries should be delivered
CONTACT_TO=hello@elaravance.design

# The "from" address. Until you verify your own domain in Resend, the shared
# onboarding@resend.dev sender works for testing.
CONTACT_FROM=Portfolio <onboarding@resend.dev>
